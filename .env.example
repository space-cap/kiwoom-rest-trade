# ==============================================================================
# [TEMPLATE] 키움증권 REST API 환경변수 설정 파일 (.env.example)
#
# 💡 사용법: 
#   1. 이 파일을 복사하여 `.env` 파일을 생성합니다.
#      (예: cp .env.example .env)
#   2. 생성된 `.env` 파일 내부의 키값 자리에 본인의 OpenAPI Key 정보를 대입합니다.
#   3. `.env` 파일은 절대로 Git 저장소에 커밋하지 마십시오.
# ==============================================================================

# 1. 키움증권 REST API Key 설정 (홈페이지에서 발급받은 키 입력)
KIWOOM_APPKEY=your_app_key_here
KIWOOM_SECRETKEY=your_secret_key_here

# 2. 모의투자 계정 여부 (실전 투자는 False, 모의투자는 True)
KIWOOM_IS_MOCK=True
